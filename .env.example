# ---- Database ----
# For local dev, SQLite works out of the box (no setup needed):
DATABASE_URL="file:./dev.db"
#
# For production, use a free Postgres database (Neon.tech or Supabase.com),
# then paste its connection string here and switch prisma/schema.prisma
# provider from "sqlite" to "postgresql" (instructions in README.md):
# DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Admin login ----
# This is the password you (the Jimlo owner) will use to log into /admin
# Change this to something only you know before going live.
ADMIN_PASSWORD="jimlo2026"

# ---- Optional: WhatsApp order notifications ----
# Leave these blank to skip. If filled in, every new order will also be
# sent to your WhatsApp via Meta's WhatsApp Cloud API. See README.md
# "Optional: WhatsApp notifications" section for setup steps.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_ADMIN_NUMBER=""
